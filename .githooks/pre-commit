#!/usr/bin/env sh

files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|json|md)$' || true)

if [ -z "$files" ]; then
  exit 0
fi

if ! npx --no-install prettier --version >/dev/null 2>&1; then
  echo "warning: prettier is not installed; skipping staged-file formatting" >&2
  exit 0
fi

printf '%s\n' "$files" | xargs npx --no-install prettier --write --ignore-unknown
printf '%s\n' "$files" | xargs git add
