{
  "name": "wildcore",
  "version": "0.1.0",
  "description": "WILDCORE: Beast Protocol - Mega Man-style mobile action platformer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:debug": "tsc -b && vite build --mode debug",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cap:sync": "vite build && npx cap sync android",
    "cap:sync:debug": "vite build --mode debug && npx cap sync android",
    "android:open": "npx cap open android",
    "hooks:install": "git config core.hooksPath .githooks",
    "postinstall": "npm run hooks:install"
  },
  "dependencies": {
    "@capacitor/android": "6.2.1",
    "@capacitor/app": "6.0.3",
    "@capacitor/core": "6.2.1",
    "@capacitor/haptics": "6.0.3",
    "@capacitor/status-bar": "6.0.3",
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.1",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
